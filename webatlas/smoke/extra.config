// Inject writable cache dirs into every task's environment so numba/scanpy and
// matplotlib can write caches inside the read-only apptainer container.
env {
  NUMBA_CACHE_DIR = '/tmp/numba_cache'
  MPLCONFIGDIR    = '/tmp/mpl_cache'
  XDG_CACHE_HOME  = '/tmp/xdg_cache'
}
process {
  // ensure /tmp caches exist before the tool runs
  beforeScript = 'mkdir -p /tmp/numba_cache /tmp/mpl_cache /tmp/xdg_cache'
}
